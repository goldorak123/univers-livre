+const fs = require('fs');
+
+const filesToProcess = ['fiche-technique.html', 'ficha-tecnica.html', 'technical-specifications.html'];
+
+for (let filename of filesToProcess) {
+    let content = fs.readFileSync(filename, 'utf8');

@@ -0,0 +1,36 @@
+const fs = require('fs');
+
+const files = fs.readdirSync('.').filter(f => f.endsWith('.html'));
+const version = '75';
+
+files.forEach(f => {
+    let content = fs.readFileSync(f, 'utf8');
+    let original = content;
+
+    // Replace v=72 or v=73 with v=75
+    content = content.replace(/service-worker\.js\?v=\d+/g, `service-worker.js?v=${version}`);
+    content = content.replace(/sw-v\d+\.js/g, `sw-v${version}.js`);
+    content = content.replace(/manifest-v\d+\.json/g, `manifest-v${version}.json`);
+
+    // Some implementations might have manifest.json?v=..
+    content = content.replace(/manifest\.json\?v=\d+/g, `manifest.json?v=${version}`);
+
+    if (content !== original) {
+        fs.writeFileSync(f, content, 'utf8');
+        console.log(`Cache busted in ${f}`);
+    }
+});
+
+// Also update service-worker.js itself to trigger byte-different update
+try {
+    let sw = fs.readFileSync('service-worker.js', 'utf8');
+    let originalSw = sw;
+    sw = sw.replace(/const CACHE_NAME = 'simon-lero-v\d+';/, `const CACHE_NAME = 'simon-lero-v${version}';`);
+
+    if (sw !== originalSw) {
+        fs.writeFileSync('service-worker.js', sw, 'utf8');
+        console.log(`Updated service-worker.js version to v${version}`);
+    }
+} catch (e) {
+    console.log('Could not update service-worker.js:', e);
+}

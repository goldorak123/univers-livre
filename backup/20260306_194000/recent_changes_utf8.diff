--- /dev/null
+++ b/fix_mobile_fonts.js
@@ -0,0 +1,46 @@
+const fs = require('fs');
+const path = require('path');
+
+const directoryPath = '.';
+
+try {
+    const files = fs.readdirSync(directoryPath).filter(f => f.endsWith('.html'));
+
+    files.forEach(f => {
+        const filePath = path.join(directoryPath, f);
+        let content = fs.readFileSync(filePath, 'utf8');
+
+        if (content.includes('.header-livre {') || content.includes('.auteur-header {')) {
+            let originalContent = content;
+
+            // Reduce auteur-header (SIMON LERO) inside media query
+            const auteurRegex = /(@media\s*\(\s*max-width:\s*768px\s*\)\s*\{[\s\S]*?\.auteur-header\s*\{[\s\S]*?font-size:)\s*[\d\.]+rem(.*?;\s*letter-spacing:)\s*[\d\.]+px;/;
+            if (auteurRegex.test(content)) {
+                content = content.replace(auteurRegex, '$1 0.45rem$2 2px;');
+            } else {
+                content = content.replace(/\.auteur-header\s*\{\s*font-size:\s*0\.6rem;\s*letter-spacing:\s*3px;/, '.auteur-header {\n            font-size: 0.45rem;\n            letter-spacing: 2px;');
+            }
+
+            // Reduce livre-header (Subtitle) inside media query and force white
+            const livreRegex = /(@media\s*\(\s*max-width:\s*768px\s*\)\s*\{[\s\S]*?\.livre-header\s*\{[\s\S]*?font-size:)\s*[\d\.]+rem(.*?;\s*letter-spacing:)\s*[\d\.]+px;/;
+            if (livreRegex.test(content)) {
+                content = content.replace(livreRegex, '$1 0.65rem$2 1px;\n            color: #ffffff !important;\n            text-shadow: 0 2px 4px rgba(0,0,0,0.8);');
+            } else {
+                content = content.replace(/\.livre-header\s*\{\s*font-size:\s*0\.8rem;\s*letter-spacing:\s*1px;/, '.livre-header {\n            font-size: 0.65rem;\n            letter-spacing: 1px;\n            color: #ffffff !important;\n            text-shadow: 0 2px 4px rgba(0,0,0,0.8);');
+            }
+
+            // Also make sure base livre-header is absolutely white
+            const baseLivreRegex = /(\.livre-header\s*\{[\s\S]*?color:\s*)#[A-Fa-f0-9]+(.*?;\s*)/;
+            if (baseLivreRegex.test(content)) {
+                content = content.replace(baseLivreRegex, '$1#ffffff$2');
+            }
+
+            if (content !== originalContent) {
+                fs.writeFileSync(filePath, content, 'utf8');
+                console.log('Updated font sizes in ' + f);
+            }
+        }
+    });
+} catch (err) {
+    console.error('Error processing files:', err);
+}

@@ -0,0 +1,65 @@
+const CACHE_NAME = 'simon-lero-v72';
+console.log('SW Loading v72...');
+const urlsToCache = [
+    '/',
+    '/livre-accueil.html',
+    '/livre-accueil-en.html',
+    '/livre-accueil-es.html',
+    '/livre.html',
+    '/livre-en.html',
+    '/livre-es.html',
+    '/media.html',
+    '/media-en.html',
+    '/media-es.html',
+    '/faq.html',
+    '/faq-en.html',
+    '/faq-es.html',
+    '/contact.html',
+    '/contact-en.html',
+    '/contact-es.html',
+    '/resume.html',
+    '/fiche-technique.html',
+    '/distribution.html',
+    '/manifest.json',
+    '/icon-192.png',
+    '/icon-512.png',
+    '/apple-touch-icon.png',
+    '/fond-livre-accueil-ultra.jpg'
+];
+
+self.addEventListener('install', event => {
+    self.skipWaiting();
+    event.waitUntil(
+        caches.open(CACHE_NAME)
+            .then(cache => cache.addAll(urlsToCache))
+    );
+});
+
+self.addEventListener('activate', event => {
+    event.waitUntil(
+        caches.keys().then(cacheNames => {
+            return Promise.all(
+                cacheNames.map(cacheName => {
+                    if (cacheName !== CACHE_NAME) {
+                        return caches.delete(cacheName);
+                    }
+                })
+            );
+        }).then(() => self.clients.claim())
+    );
+});
+
+self.addEventListener('fetch', event => {
+    // Strat??gie Network-first : On essaie le r??seau, si ??a ??choue (hors ligne), on prend le cache.
+    event.respondWith(
+        fetch(event.request)
+            .then(response => {
+                // Si la r??ponse est valide, on peut optionnellement mettre ?? jour le cache ici
+                // Mais pour l'instant on se contente de la renvoyer pour garantir la fra??cheur.
+                return response;
+            })
+            .catch(() => {
+                return caches.match(event.request);
+            })
+    );
+});

new file mode 100644
index 0000000..2c09197
--- /dev/null
+++ b/force_top_margin.js
@@ -0,0 +1,38 @@
+const fs = require('fs');
+const files = [
+    'livre.html', 'livre-en.html', 'livre-es.html',
+    'ficha-tecnica.html', 'fiche-technique.html', 'fiche-technique-en.html'
+];
+
+files.forEach(file => {
+    if (!fs.existsSync(file)) return;
+
+    let content = fs.readFileSync(file, 'utf8');
+
+    // We will append a final style block right before </head> to guarantee it overrides any earlier definitions.
+    // This fixes the issue where previous scripts injected things at the top of <style>.
+    const overrideStyle = `
+<!-- FORCE TOP MARGIN FIX -->
+<style>
+    .hero-stage { padding-top: 160px !important; }
+    .hero { padding-top: 160px !important; }
+    
+    @media (max-width: 1000px) {
+        .hero-stage { padding-top: 100px !important; }
+        .hero { padding-top: 100px !important; }
+    }
+</style>
+</head>`;
+
+    // Remove any previous forcing if it exists (for idempotency)
+    const removeRegex = /<!-- FORCE TOP MARGIN FIX -->[\s\S]*?<\/style>\s*<\/head>/g;
+    if (content.match(removeRegex)) {
+        content = content.replace(removeRegex, '</head>');
+    }
+
+    if (content.includes('</head>')) {
+        content = content.replace('</head>', overrideStyle);
+        fs.writeFileSync(file, content, 'utf8');
+        console.log(`Forced margin fix on ${file}`);
+    }
+});

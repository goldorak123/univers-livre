diff --git a/crop_header_bottom.js b/crop_header_bottom.js
new file mode 100644
index 0000000..254773c
--- /dev/null
+++ b/crop_header_bottom.js
@@ -0,0 +1,24 @@
+const fs = require('fs');
+const files = [
+    'livre.html', 'livre-en.html', 'livre-es.html',
+    'ficha-tecnica.html', 'fiche-technique.html', 'fiche-technique-en.html'
+];
+
+files.forEach(file => {
+    if (!fs.existsSync(file)) return;
+
+    let content = fs.readFileSync(file, 'utf8');
+    let dirty = false;
+
+    // Shift the background position up to crop the bottom edge artifact (the line and '12')
+    const oldBgPos = /background-position:\s*center\s+bottom;/g;
+    if (content.match(oldBgPos)) {
+        content = content.replace(oldBgPos, 'background-position: center 80%; /* crop bottom edge */');
+        dirty = true;
+    }
+
+    if (dirty) {
+        fs.writeFileSync(file, content, 'utf8');
+        console.log(`Cropped bottom edge of header in ${file}`);
+    }
+});

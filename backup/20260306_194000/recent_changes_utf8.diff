diff --git a/fix_clipping.js b/fix_clipping.js
new file mode 100644
index 0000000..2571e4e
--- /dev/null
+++ b/fix_clipping.js
@@ -0,0 +1,33 @@
+const fs = require('fs');
+const files = ['livre-accueil.html', 'livre-accueil-en.html', 'livre-accueil-es.html'];
+
+files.forEach(file => {
+    if (!fs.existsSync(file)) return;
+
+    let content = fs.readFileSync(file, 'utf8');
+    let dirty = false;
+
+    // Change left: -40px  to  left: -20px or 0 to bring it into the screen a bit
+    const leftRegex = /left:\s*-40px;/g;
+    if (content.match(leftRegex)) {
+        content = content.replace(leftRegex, 'left: -10px;');
+        dirty = true;
+    }
+
+    // Since layout-grid has overflow: hidden in es and en, we should remove it 
+    // to prevent clipping
+    const layoutGridRegex = /\.layout-grid\s*\{[^}]*overflow:\s*hidden;[^}]*\}/g;
+
+    // We can just globally replace overflow: hidden; in layout-grid if we match it, 
+    // but simpler: replace it generally if it's right after z-index: 10;
+    const zIndexOverflow = /z-index:\s*10;\s*overflow:\s*hidden;/g;
+    if (content.match(zIndexOverflow)) {
+        content = content.replace(zIndexOverflow, 'z-index: 10;\n      /* overflow hidden removed */');
+        dirty = true;
+    }
+
+    if (dirty) {
+        fs.writeFileSync(file, content, 'utf8');
+        console.log(`Fixed clipping on ${file}`);
+    }
+});
diff --git a/fix_header.js b/fix_header.js
new file mode 100644
index 0000000..85aa752
--- /dev/null
+++ b/fix_header.js
@@ -0,0 +1,56 @@
+const fs = require('fs');
+const files = ['fiche-technique.html', 'ficha-tecnica.html', 'technical-specifications.html'];
+
+files.forEach(f => {
+    try {
+        let text = fs.readFileSync(f, 'utf8');
+
+        // Remove old after/before gradients
+        text = text.replace(
+            /   \.header-livre::before \{[\s\S]*?pointer-events: none;\s*\}/,
+            `   .header-livre::before {
+        content: "";
+        position: absolute;
+        bottom: -5px;
+        right: -10px;
+        width: 120px;
+        height: 60px;
+        background: #030303;
+        filter: blur(10px);
+        z-index: 5;
+        pointer-events: none;
+    }`
+        );
+
+        text = text.replace(
+            /rgba\(0, 0, 0, 0\) 50%, rgba\(0, 0, 0, 0\.4\) 80%, rgba\(0, 0, 0, 1\) 100%/,
+            'rgba(3, 3, 3, 0) 50%, rgba(3, 3, 3, 0.6) 80%, rgba(3, 3, 3, 1) 100%'
+        );
+
+        // Make Spanish title white
+        if (f === 'ficha-tecnica.html') {
+            text = text.replace(
+                /    \.titre-memoire \{[\s\S]*?filter: drop-shadow\(0 4px 6px rgba\(0, 0, 0, 0\.8\)\);\s*\}/,
+                `    .titre-memoire {
+        font-family: "Playfair Display", serif;
+        color: #ffffff;
+        font-size: clamp(3rem, 10vw, 5.5rem);
+        font-weight: 900;
+        letter-spacing: 0.15em;
+        text-transform: uppercase;
+        margin: 0;
+        text-align: center;
+        position: relative;
+        z-index: 10;
+        padding: 5px 20px;
+        filter: drop-shadow(0 4px 6px rgba(0, 0, 0, 0.8));
+    }`
+            );
+        }
+
+        fs.writeFileSync(f, text, 'utf8');
+        console.log('Fixed ' + f);
+    } catch (e) {
+        console.error('Error in ' + f + ': ' + e);
+    }
+});
diff --git a/fix_injection_spot.js b/fix_injection_spot.js
new file mode 100644
index 0000000..89a5873
--- /dev/null
+++ b/fix_injection_spot.js
@@ -0,0 +1,52 @@
+const fs = require('fs');
+const files = ['livre-accueil.html', 'livre-accueil-en.html', 'livre-accueil-es.html'];
+
+const words = {
+    'livre-accueil.html': 'CLAIR',
+    'livre-accueil-en.html': 'MOON',
+    'livre-accueil-es.html': 'LUNA'
+};
+
+files.forEach(file => {
+    if (!fs.existsSync(file)) return;
+
+    let content = fs.readFileSync(file, 'utf8');
+    let dirty = false;
+
+    const txt = words[file];
+    const topHTML = `<div class="hero-background-title">${txt}</div>`;
+
+    // 1. Clean up accidental CSS injections
+    // It accidentally did: .layout-grid { \n <div class="hero-background-title">CLAIR</div>
+    const badCssRegex = /\.layout-grid \{\s*<div class="hero-background-title">.*?<\/div>/g;
+    if (content.match(badCssRegex)) {
+        content = content.replace(badCssRegex, '.layout-grid {');
+        dirty = true;
+    }
+
+    // Also remove any existing valid HTML so we don't duplicate
+    const goodHtmlRegex = /<div class="hero-background-title">.*?<\/div>\s*/g;
+    if (content.match(goodHtmlRegex)) {
+        content = content.replace(goodHtmlRegex, '');
+        dirty = true;
+    }
+

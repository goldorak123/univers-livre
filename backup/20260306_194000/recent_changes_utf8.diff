+    content = content.replace(/(<header class="hero(?:-stage)?(?:[^">]*)">)/, newHeaderBlock + '\n\n$1');
+
+    content = content.replace(/\.hero\s*\{\s*padding:\s*[0-9A-Za-z\s]+;/g, '.hero { padding: 40px 20px 20px;');

+    'livre-accueil-es.html': 'LUNA'
+};
+
+files.forEach(file => {
+    if (!fs.existsSync(file)) return;
+
+    let content = fs.readFileSync(file, 'utf8');
+    let dirty = false;
+
+    // We want to make sure the HTML is ACTUALLY injected.
+    const txt = words[file];
+    const topHTML = `\n    <div class="hero-background-title">${txt}</div>\n`;
+
+    // 1. Remove if it already exists to avoid duplicates
+    const regexHtml = /<div class="hero-background-title">.*?<\/div>\s*/g;
+    if (content.match(regexHtml)) {
+        content = content.replace(regexHtml, '');
+    }
+
+    // 2. Inject right after <div class="layout-grid">
+    if (content.includes('<div class="layout-grid">')) {
+        content = content.replace('<div class="layout-grid">', '<div class="layout-grid">' + topHTML);
+        dirty = true;
+    }
+
+    // 3. Make sure the CSS is using Inter and 15% opacity like the user wants
+    const oldCssRegex = /\.hero-background-title\s*\{[\s\S]*?\}/;
+    const correctCss = `.hero-background-title {
+      font-family: 'Inter', sans-serif;
+      font-size: clamp(10rem, 30vw, 28rem);
+      font-weight: 900;
+      color: rgba(216, 178, 90, 0.15);
+      -webkit-text-stroke: 1px rgba(216, 178, 90, 0.15);
+      position: absolute;
+      top: 40px;
+      left: -40px;
+      line-height: 0.9;
+      text-transform: uppercase;
+      z-index: -1;
+      pointer-events: none;
+      letter-spacing: -0.05em;
+      animation: slideInLeft 1.5s cubic-bezier(0.2, 0.8, 0.2, 1);
+      transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
+      white-space: nowrap;
+    }`;
+
+    if (content.match(oldCssRegex)) {
+        content = content.replace(oldCssRegex, correctCss);
+        dirty = true;
+    } else {
+        // Fallback: append before </style> if not found at all
+        content = content.replace('</style>', '\n' + correctCss + '\n</style>');
+        dirty = true;
+    }
+
+    if (dirty) {
+        fs.writeFileSync(file, content, 'utf8');
+        console.log(`Re-injected HTML and verified CSS in ${file}`);
+    }
+});

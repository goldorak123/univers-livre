diff --git a/set_opacity_9.js b/set_opacity_9.js
new file mode 100644
index 0000000..5e44756
--- /dev/null
+++ b/set_opacity_9.js
@@ -0,0 +1,28 @@
+const fs = require('fs');
+const files = ['livre-accueil.html', 'livre-accueil-en.html', 'livre-accueil-es.html'];
+
+files.forEach(file => {
+    if (!fs.existsSync(file)) return;
+
+    let content = fs.readFileSync(file, 'utf8');
+    let dirty = false;
+
+    // Change the color from 0.04 to 0.09
+    const colorRegex = /color:\s*rgba\(216,\s*178,\s*90,\s*0\.04\);/g;
+    if (content.match(colorRegex)) {
+        content = content.replace(colorRegex, 'color: rgba(216, 178, 90, 0.09);');
+        dirty = true;
+    }
+
+    // Just in case it was somehow left at 15% originally
+    const colorRegex15 = /color:\s*rgba\(216,\s*178,\s*90,\s*0\.15\);/g;
+    if (content.match(colorRegex15)) {
+        content = content.replace(colorRegex15, 'color: rgba(216, 178, 90, 0.09);');
+        dirty = true;
+    }
+
+    if (dirty) {
+        fs.writeFileSync(file, content, 'utf8');
+        console.log(`Set opacity to 9% in ${file}`);
+    }
+});

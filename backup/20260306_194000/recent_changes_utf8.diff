diff --git a/reduce_opacity.js b/reduce_opacity.js
new file mode 100644
index 0000000..424b748
--- /dev/null
+++ b/reduce_opacity.js
@@ -0,0 +1,28 @@
+const fs = require('fs');
+const files = ['livre-accueil.html', 'livre-accueil-en.html', 'livre-accueil-es.html'];
+
+files.forEach(file => {
+    if (!fs.existsSync(file)) return;
+
+    let content = fs.readFileSync(file, 'utf8');
+    let dirty = false;
+
+    // We change the solid color from 0.15 to 0.04 (4%)
+    const colorRegex = /color:\s*rgba\(216,\s*178,\s*90,\s*0\.15\);/g;
+    if (content.match(colorRegex)) {
+        content = content.replace(colorRegex, 'color: rgba(216, 178, 90, 0.04);');
+        dirty = true;
+    }
+
+    // Also ensuring no stroke is left over just in case, or if it was set to 0.15 there too
+    const strokeRegex = /-webkit-text-stroke:\s*1px\s*rgba\(216,\s*178,\s*90,\s*0\.15\);/g;
+    if (content.match(strokeRegex)) {
+        content = content.replace(strokeRegex, '-webkit-text-stroke: 1px rgba(216, 178, 90, 0.00); /* Removed */');
+        dirty = true;
+    }
+
+    if (dirty) {
+        fs.writeFileSync(file, content, 'utf8');
+        console.log(`Reduced opacity to 4% in ${file}`);
+    }
+});
diff --git a/remove_fiche_image.js b/remove_fiche_image.js
new file mode 100644
index 0000000..5ef5745
--- /dev/null
+++ b/remove_fiche_image.js
@@ -0,0 +1,62 @@
+const fs = require('fs');
+const files = [
+    'livre.html', 'livre-en.html', 'livre-es.html',
+    'ficha-tecnica.html', 'fiche-technique.html', 'fiche-technique-en.html'
+];
+
+files.forEach(file => {
+    if (!fs.existsSync(file)) return;
+
+    let content = fs.readFileSync(file, 'utf8');
+    let dirty = false;
+
+    // 1. Adjust margin to 120px in the forced CSS rule
+    const oldStyle = `
+<!-- FORCE TOP MARGIN FIX -->
+<style>
+    .hero-stage { padding-top: 160px !important; }
+    .hero { padding-top: 160px !important; }
+    
+    @media (max-width: 1000px) {
+        .hero-stage { padding-top: 100px !important; }
+        .hero { padding-top: 100px !important; }
+    }
+</style>
+</head>`;
+    const newStyle = `
+<!-- FORCE TOP MARGIN FIX -->
+<style>
+    .hero-stage { padding-top: 120px !important; }
+    .hero { padding-top: 120px !important; }
+    
+    @media (max-width: 1000px) {
+        .hero-stage { padding-top: 100px !important; }
+        .hero { padding-top: 100px !important; }
+    }
+</style>
+</head>`;
+
+    if (content.includes(oldStyle)) {
+        content = content.replace(oldStyle, newStyle);
+        dirty = true;
+    } else {
+        // Fallback replacement if exact match fails
+        content = content.replace(/padding-top:\s*160px\s*!important;/g, 'padding-top: 120px !important;');
+        dirty = true;
+    }
+
+    // 2. Remove the book image block if it's a "fiche" or "ficha" page
+    if (file.includes('fich')) {
+        const heroBlockRegex = /<header\s+class="hero">[\s\S]*?<\/header>/g;
+        if (content.match(heroBlockRegex)) {
+            content = content.replace(heroBlockRegex, '');
+            dirty = true;
+            console.log(`Removed image block from ${file}`);
+        }
+    }
+
+    if (dirty) {
+        fs.writeFileSync(file, content, 'utf8');
+        console.log(`Updated ${file}: Margin set to 120px`);
+    }
+});

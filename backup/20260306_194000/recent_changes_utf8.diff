+++ b/apply_modern_font.js
@@ -0,0 +1,91 @@
+const fs = require('fs');
+const files = ['livre-accueil.html', 'livre-accueil-en.html', 'livre-accueil-es.html'];
+
+const words = {
+    'livre-accueil.html': { top: 'CLAIR', bottom: 'LUNE' },
+    'livre-accueil-en.html': { top: 'MOON', bottom: 'LIGHT' },
+    'livre-accueil-es.html': { top: 'LUNA', bottom: 'CLARA' }
+};
+
+files.forEach(file => {
+    if (!fs.existsSync(file)) return;
+
+    let content = fs.readFileSync(file, 'utf8');
+    let dirty = false;
+
+    // 1. Add Montserrat to Google Fonts if not present
+    if (!content.includes('Montserrat')) {
+        content = content.replace(
+            /href="https:\/\/fonts.googleapis.com\/css2\?family=Cinzel[^"]*"/,
+            'href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700;900&family=Inter:wght@200;300;400;600;800&family=Montserrat:wght@900&display=swap"'
+        );
+        dirty = true;
+    }
+
+    // 2. Re-inject the CSS for .hero-background-title using Montserrat
+    const newCSS = `
+    .hero-background-title {
+      font-family: 'Montserrat', 'Inter', sans-serif;
+      font-size: clamp(10rem, 30vw, 28rem);
+      font-weight: 900;
+      color: rgba(201, 162, 77, 0.08); /* More subtle */
+      -webkit-text-stroke: 1px rgba(201, 162, 77, 0.15);
+      position: absolute;
+      top: 40px;
+      left: -5%;
+      line-height: 0.9;
+      text-transform: uppercase;
+      z-index: -1;
+      pointer-events: none;
+      letter-spacing: -0.02em; /* Tighter tracking for modern feel */
+      animation: slideInLeft 1.5s cubic-bezier(0.2, 0.8, 0.2, 1);
+      transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
+    }
+
+    .hero-background-title-bottom {
+      font-family: 'Montserrat', 'Inter', sans-serif;
+      font-size: clamp(10rem, 30vw, 28rem);
+      font-weight: 900;
+      color: rgba(201, 162, 77, 0.04);
+      -webkit-text-stroke: 1px rgba(201, 162, 77, 0.1);
+      position: absolute;
+      bottom: -10%;
+      right: -5%;
+      line-height: 0.9;
+      text-transform: uppercase;
+      z-index: -1;
+      pointer-events: none;
+      letter-spacing: -0.02em;
+      animation: slideInRight 1.5s cubic-bezier(0.2, 0.8, 0.2, 1);
+      transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
+    }
+`;
+
+    // Try to insert right before .content-left to keep css grouped, 
+    // but if it's already there skip
+    if (!content.includes('font-family: \'Montserrat\'')) {
+        content = content.replace('.content-left {', newCSS + '\n    .content-left {');
+        dirty = true;
+    }
+
+    // 3. Re-inject the HTML text markers
+    const txt = words[file];
+    const topHTML = `\n    <div class="hero-background-title">${txt.top}</div>\n`;
+    const bottomHTML = `\n    <div class="hero-background-title-bottom">${txt.bottom}</div>\n`;
+
+    if (!content.includes('class="hero-background-title"')) {
+        content = content.replace('<div class="layout-grid">', '<div class="layout-grid">' + topHTML);
+        dirty = true;
+    }
+
+    // Insert bottom mark before closing main
+    if (!content.includes('class="hero-background-title-bottom"')) {
+        content = content.replace('<div class="decor-float"></div>', bottomHTML + '    <div class="decor-float"></div>');
+        dirty = true;
+    }
+
+    if (dirty) {
+        fs.writeFileSync(file, content, 'utf8');
+        console.log(`Applied modern sans-serif font to ${file}`);
+    }
+});

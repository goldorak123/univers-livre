diff --git a/backup/phase2_header_margins_done/remove_empty_hero.js b/backup/phase2_header_margins_done/remove_empty_hero.js
new file mode 100644
index 0000000..15d37fb
--- /dev/null
+++ b/backup/phase2_header_margins_done/remove_empty_hero.js
@@ -0,0 +1,20 @@
+const fs = require('fs');
+const files = fs.readdirSync('.').filter(f => f.endsWith('.html'));
+
+files.forEach(file => {
+    let content = fs.readFileSync(file, 'utf8');
+    let dirty = false;
+
+    // Matches <header class="hero"> exactly with optional whitespace/newlines followed by </header>
+    const emptyHeroRegex = /<header class="hero">\s*<\/header>/g;
+
+    if (content.match(emptyHeroRegex)) {
+        content = content.replace(emptyHeroRegex, '');
+        dirty = true;
+    }
+
+    if (dirty) {
+        fs.writeFileSync(file, content, 'utf8');
+        console.log(`Removed empty hero from ${file}`);
+    }
+});

diff --git a/restore_giant_inter.js b/restore_giant_inter.js
new file mode 100644
index 0000000..7cb7283
--- /dev/null
+++ b/restore_giant_inter.js
@@ -0,0 +1,61 @@
+const fs = require('fs');
+const files = ['livre-accueil.html', 'livre-accueil-en.html', 'livre-accueil-es.html'];
+
+files.forEach(file => {
+    if (!fs.existsSync(file)) return;
+
+    let content = fs.readFileSync(file, 'utf8');
+    let dirty = false;
+
+    // 1. Remove the bottom text HTML
+    const bottomHtmlRegex = /<div class="hero-background-title-bottom">.*?<\/div>\s*/g;
+    if (content.match(bottomHtmlRegex)) {
+        content = content.replace(bottomHtmlRegex, '');
+        dirty = true;
+    }
+
+    // 2. Replace the CSS for both background titles with only the top one, using Inter at 15%
+    const cssRegex = /\.hero-background-title\s*\{[\s\S]*?\}\s*\.hero-background-title-bottom\s*\{[\s\S]*?\}/;
+    const newCss = `.hero-background-title {
+      font-family: 'Inter', sans-serif;
+      font-size: clamp(10rem, 30vw, 28rem);
+      font-weight: 900;
+      color: rgba(216, 178, 90, 0.15);
+      -webkit-text-stroke: 1px rgba(216, 178, 90, 0.15);
+      position: absolute;
+      top: 40px;
+      left: -40px;
+      line-height: 0.9;
+      text-transform: uppercase;
+      z-index: -1;
+      pointer-events: none;
+      letter-spacing: -0.05em;
+      animation: slideInLeft 1.5s cubic-bezier(0.2, 0.8, 0.2, 1);
+      transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
+      white-space: nowrap;
+    }`;
+
+    if (content.match(cssRegex)) {
+        content = content.replace(cssRegex, newCss);
+        dirty = true;
+    } else {
+        // Fallback: maybe they aren't together, just replace hero-background-title
+        const singleCssRegex = /\.hero-background-title\s*\{[\s\S]*?\}/;
+        if (content.match(singleCssRegex) && !content.includes("color: rgba(216, 178, 90, 0.15)")) {
+            content = content.replace(singleCssRegex, newCss);
+            dirty = true;
+        }
+    }
+
+    // Also remove any remaining hero-background-title-bottom CSS if it was dangling
+    const danglingRegex = /\.hero-background-title-bottom\s*\{[\s\S]*?\}/;
+    if (content.match(danglingRegex)) {
+        content = content.replace(danglingRegex, '');
+        dirty = true;
+    }
+
+    if (dirty) {
+        fs.writeFileSync(file, content, 'utf8');
+        console.log(`Restored giant Inter font at the top in ${file}`);
+    }
+});
